<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.xxw.coedit.mapper.UserMapper">

    <select id="selectUserByUsername" resultType="com.xxw.coedit.entity.User" parameterType="java.lang.String">
        select
            id,
            username,
            password,
            created_at
        from users
        where username = #{username}
        LIMIT 1
    </select>
</mapper>
